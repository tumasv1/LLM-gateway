# Скопируй в .env и заполни. .env в git НЕ попадает.

# ── Master key шлюза (админ + дефолтный доступ). Длинный случайный секрет, начинается с sk- ──
# сгенерировать: openssl rand -hex 24  →  префикс sk-
LITELLM_MASTER_KEY=sk-CHANGE-ME-long-random

# ── Postgres (данные платформы: virtual keys, бюджеты, история расходов) ──
POSTGRES_PASSWORD=change-me-db
# DATABASE_URL должен содержать тот же пароль, что и POSTGRES_PASSWORD; хост = имя сервиса postgres
DATABASE_URL=postgresql://litellm:change-me-db@postgres:5432/litellm

# ── Redis (счётчики rpm/tpm для балансировки + кэш) ──
REDIS_PASSWORD=change-me-redis

# ── Ключи провайдеров (живут ТОЛЬКО здесь, в одном месте; клиентам не раздаются) ──
OPENROUTER_API_KEY=sk-or-v1-...
NANOGPT_API_KEY=sk-nano-...
DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── Langfuse (Этап 3, пока пусто) ──
# LANGFUSE_HOST=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
